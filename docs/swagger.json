{
    "swagger": "2.0",
    "info": {
        "description": "API прокси-сервиса для управления IP-доступом, rate limiting, мониторингом и кэшированием.",
        "title": "Vet Clinic Proxy API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8000",
    "basePath": "/",
    "paths": {
        "/example/cache": {
            "delete": {
                "description": "Очищает весь кэш или удаляет запись по ключу",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "cache"
                ],
                "summary": "Инвалидация кэша",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Ключ кэша",
                        "name": "key",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/example/ip_access/allowlists": {
            "get": {
                "description": "Возвращает список правил доступа из базы данных",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "ip_access"
                ],
                "summary": "Получить все IP-правила",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/domain.IPRule"
                            }
                        }
                    }
                }
            },
            "post": {
                "description": "Создает новое правило в whitelist/blacklist/greylist",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "ip_access"
                ],
                "summary": "Добавить IP-правило",
                "parameters": [
                    {
                        "description": "Новое IP-правило",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/http.CreateIPRuleRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/example/ip_access/allowlists/{id}": {
            "delete": {
                "description": "Удаляет правило по ID",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "ip_access"
                ],
                "summary": "Удалить IP-правило",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "ID правила",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/example/ip_access/check": {
            "get": {
                "description": "Проверяет, разрешен ли доступ для указанного IP",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "ip_access"
                ],
                "summary": "Проверить IP",
                "parameters": [
                    {
                        "type": "string",
                        "description": "IP адрес",
                        "name": "ip",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/example/metrics": {
            "get": {
                "description": "Возвращает статистику сервиса в памяти",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "monitoring"
                ],
                "summary": "Получить метрики",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "domain.IPRule": {
            "type": "object",
            "properties": {
                "created_at": {
                    "type": "string"
                },
                "id": {
                    "type": "integer"
                },
                "list_type": {
                    "type": "string"
                },
                "updated_at": {
                    "type": "string"
                },
                "value": {
                    "type": "string"
                }
            }
        },
        "http.CreateIPRuleRequest": {
            "type": "object",
            "properties": {
                "list_type": {
                    "type": "string"
                },
                "value": {
                    "type": "string"
                }
            }
        }
    }
}